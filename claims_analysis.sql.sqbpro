SELECT Claim_Type, SUM(Claim_Amount) AS total_cost
FROM claims
GROUP BY Claim_Type
ORDER BY total_cost DESC;
SELECT Status, COUNT(*) AS count
FROM claims
GROUP BY Status;
SELECT Claim_Type, AVG(Processing_Days) AS avg_days
FROM claims
GROUP BY Claim_Type
ORDER BY avg_days DESC;
SELECT Region, COUNT(*) AS total_claims
FROM claims
GROUP BY Region
ORDER BY total_claims DESC;</sql><current_tab id="0"/></tab_sql></sqlb_project>
